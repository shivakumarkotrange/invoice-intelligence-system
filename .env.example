# FastAPI Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# File Upload Settings
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=temp_uploads
CLEANUP_TEMP_FILES=true

# System Dependencies (Only needed if Tesseract/Poppler are not in system PATH)
# Set these if you get OCR errors about missing tesseract or poppler
# Windows example:
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
# POPPLER_PATH=C:\Program Files\poppler\Library\bin
# TESSERACT_PATH=
# POPPLER_PATH=

# ML Model Settings
OCR_LANGUAGE=eng
NER_BATCH_SIZE=1
EMBEDDING_BATCH_SIZE=32
CLUSTERING_EPS=0.1
CLUSTERING_MIN_SAMPLES=3
ANOMALY_CONTAMINATION=0.1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
